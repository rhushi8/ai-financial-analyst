# Required
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct

# Optional - override defaults
APP_ENV=dev
FINANCE_AI_EMBEDDING_MODE=sentence
FINANCE_AI_VECTORSTORE_ROOT=data/vectorstore
FINANCE_AI_LOW_GROUNDING_THRESHOLD=0.45
FINANCE_AI_AGENT_PLANNER_MODE=hybrid
FINANCE_AI_ENABLE_RERANK=true
FINANCE_AI_RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
FINANCE_AI_SHOW_DEBUG_PANELS=false
